# ----------------------------------------------------------------------
# CMake 构建目录
# ----------------------------------------------------------------------
/out/
/build/
/bin/

# ----------------------------------------------------------------------
# CMake 缓存和自动生成的文件 (以防在源码目录意外运行 cmake)
# ----------------------------------------------------------------------
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile
*.ninja

# ----------------------------------------------------------------------
# IDE & 编辑器配置 (Visual Studio, VS Code 等)
# ----------------------------------------------------------------------
.vs/
.vscode/
*.sln
*.vcxproj
*.vcxproj.*
*.suo
*.user

# ----------------------------------------------------------------------
# 编译生成的二进制文件和中间对象
# ----------------------------------------------------------------------
*.obj
*.o
*.exe
*.dll
*.lib
*.a
*.pdb
*.ilk